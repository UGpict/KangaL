# KangaL — local environment template.
# Copy to `.env.local` and fill in. Never commit `.env.local`.

# GCP project that hosts the Vertex AI API used by Gemini.
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Vertex AI region. Default is us-central1 if unset.
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini model override. Default is gemini-2.5-flash if unset.
# GEMINI_MODEL=gemini-2.5-flash

# Set to 1 to run the integration tests that hit the real Vertex AI.
# These tests require ADC credentials (gcloud auth application-default login).
# INTEGRATION=1

# Google Web Risk Lookup API key (server-side only). Used by the
# checkUrlReputation investigation tool. Get one by enabling Web Risk API in
# the GCP console and creating an API key.
# WEB_RISK_API_KEY=your-web-risk-api-key

# Gmail OAuth (server-side only). Used by the inbox-read opener (S2).
# Create a dedicated OAuth 2.0 client (type: Web application) under the
# KangaL GCP project — do NOT reuse another project's client. Register the
# authorized redirect URI for both prod and local before use:
#   prod:  https://kangal-649847191589.us-central1.run.app/api/gmail/callback
#   local: http://localhost:3000/api/gmail/callback
# GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
# Must exactly match one registered redirect URI on the OAuth client above.
#   local: http://localhost:3000/api/gmail/callback
#   prod:  https://kangal-649847191589.us-central1.run.app/api/gmail/callback
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Cookie encryption key for the Gmail session (AES-256-GCM). Must be a
# 32-byte key, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# In production, supply this via Secret Manager — never commit a real key.
# GMAIL_SESSION_KEY=your-base64-encoded-32-byte-key
