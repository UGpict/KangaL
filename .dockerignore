# Keep the build context small and secrets out of the image.
node_modules
.next
.git
.gitignore

# secrets / local env — never copy into the image
.env
.env.*
!.env.example
*.pem
*.key
*-service-account.json

# dev / test / docs cruft
coverage
spike
implementation-notes
docs
**/__tests__
**/*.test.ts
**/*.test.tsx
scripts
.claude
.vscode
.idea
README.md
*.md
